# GitHub org to contribute to
GITHUB_ORG=myorg

# Directory where org repos are cloned
WORKSPACE="$HOME/myorg"

# Directory where heartbeat state and prompts live
HEARTBEAT_HOME="$HOME/claude"

# Bot identity for commits
BOT_NAME="myorg-heartbeat[bot]"
BOT_EMAIL="myorg-heartbeat[bot]@users.noreply.github.com"

# Email notification (leave empty to skip sending email)
NOTIFY_TO=""
NOTIFY_FROM=""

# Name used in PR/issue footers ("$OWNER_NAME has not reviewed this yet")
OWNER_NAME="Your Name"

# Usage check command (optional). If set, runs before each cycle.
# Must print a number to stdout. Cycle is skipped if the number > PACE_THRESHOLD.
USAGE_CHECK_CMD=""
PACE_THRESHOLD=5

# Cycle timing (seconds)
CYCLE_MIN_SECONDS=7200
CYCLE_JITTER_SECONDS=1800

# Release check interval in seconds (default: 5 days)
RELEASE_CHECK_INTERVAL=432000

# Claude CLI options
CLAUDE_MODEL=opus
CLAUDE_EFFORT=max
